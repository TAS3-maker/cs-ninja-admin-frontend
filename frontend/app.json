{
  "expo": {
    "name": "CSninja",
    "slug": "csninja",
    "scheme": "csninja",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.csninja.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Pick a photo for your profile picture",
        "NSCameraUsageDescription": "Take a profile picture with your camera"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a237e"
      },
      "package": "com.csninja.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a237e"
        }
      ],
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Pick a photo for your profile picture",
          "cameraPermission": "Take a profile picture with your camera"
        }
      ],
      "expo-screen-orientation",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1a237e"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
